{
  "name": "@believe/claude-eyes",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Give Claude Code eyes on your dev server. Live UI feedback loop with multimodal injection. Side-car daemon + cmux WKWebView bridge.",
  "license": "GPL-3.0-or-later",
  "author": "Believe Global <opensource@believe-global.com>",
  "homepage": "https://github.com/BELIEVE-IT-GROUP/claude-eyes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BELIEVE-IT-GROUP/claude-eyes.git"
  },
  "bugs": {
    "url": "https://github.com/BELIEVE-IT-GROUP/claude-eyes/issues"
  },
  "keywords": [
    "claude-code",
    "cmux",
    "ai-agents",
    "live-preview",
    "playwright",
    "wkwebview",
    "visual-feedback",
    "multimodal",
    "frontend-dev",
    "lovable-alternative"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "daemon": "tsx daemon/cli.ts",
    "bridge": "tsx bridge/index.ts",
    "test": "node --test --import tsx ./tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "claude-eyes": "./daemon/cli.ts"
  },
  "files": [
    "bridge/",
    "contracts/",
    "daemon/",
    "hooks/",
    "skill/",
    "LICENSE",
    "README.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "chokidar": "^3.6.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "playwright": "^1.60.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
