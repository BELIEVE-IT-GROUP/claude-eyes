# Dependencies
node_modules/
.pnp
.pnp.js
package-lock.json.bak

# Build output
dist/
build/
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
/tmp/claude-eyes-*.log

# Runtime state (gitignored by design — generated on every daemon run)
.workspace/
.claude/eyes/
.claude/eyes-e2e/
!.claude/eyes/.gitkeep

# Recon artifacts (cloned upstream, kept local, never published)
.recon/

# E2E pilot scratch
.e2e/

# Local example state — only the source tree of docs/examples/* is tracked
docs/examples/*/node_modules/
docs/examples/*/dist/
docs/examples/*/.claude/

# Editor + OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~

# Per-user env
.env
.env.local
.env.*.local

# Build reports (private, generated by internal workflows)
BUILD_REPORT.md
FORK_REPORT.md

# Private launch material (do not publish)
docs/MARKETING.md
